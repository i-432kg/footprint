# MySQL for local docker compose
MYSQL_DATABASE=footprint_local
MYSQL_USER=footprint
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# Spring datasource for local profile
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/footprint_local?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Tokyo&characterEncoding=utf8
SPRING_DATASOURCE_USERNAME=footprint
SPRING_DATASOURCE_PASSWORD=change-me
APP_LOCAL_SEED_TEST_PASSWORD=change-me-local-seed
